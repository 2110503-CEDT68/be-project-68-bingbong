{
  "info": {
    "_postman_id": "6fc371ee-1848-49d2-a4be-a54daebd2f0a",
    "name": "09.Admin Login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52483416"
  },
  "item": [
    {
      "name": "Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.environment.set(\"TOKEN\", pm.response.json().token);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Token is valid\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.token).to.not.be.null;\r",
              "    pm.expect(jsonData.token).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"admin@gmail.com\",\r\n    \"password\": \"12345678\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v1/auth/login",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    }
  ]
}