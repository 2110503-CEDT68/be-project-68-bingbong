{
  "info": {
    "_postman_id": "1e56f9cb-f30b-4035-8e87-b54d27e31ceb",
    "name": "02.User Login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52483416"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.environment.set(\"TOKEN\", pm.response.json().token);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Token is valid\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.token).to.not.be.null;\r",
              "    pm.expect(jsonData.token).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.execution.setNextRequest(\"getMe\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"user@gmail.com\",\r\n    \"password\": \"12345678\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v1/auth/login",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "getMe",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.environment.set(\"userID\", pm.response.json().data._id);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"User role is user\", function () {\r",
              "    pm.expect(pm.response.json().data.role).to.eql(\"user\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v1/auth/me",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "me"
          ]
        }
      },
      "response": []
    }
  ]
}