@startuml User Authentication Sequence Diagram

header BingBong's Sequence Diagram
footer Page %page% of %lastpage%
title "User Authentication Sequence Diagram"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client -> server ++: req.post('/api/v1/auth/register')
server -> routerAuth ++: app.use('/api/v1/auth', auth)
routerAuth -> controllersAuth ++: register()
controllersAuth -> modelUser ++: create(req.body)
modelUser -> UsersDatabase ++: UserSchema
UsersDatabase --> modelUser --: user
controllersAuth <-- modelUser --: user
controllersAuth -> controllersAuth ++: sendTokenResponse(user)
controllersAuth -> client --: token + cookie response

client -> server ++: req.post('/api/v1/auth/login')
server -> routerAuth ++: app.use('/api/v1/auth', auth)
routerAuth -> controllersAuth ++: login()
controllersAuth -> modelUser ++: findOne({email}).select('+password')
modelUser -> UsersDatabase ++: query
UsersDatabase --> modelUser --: user
controllersAuth <-- modelUser --: user
controllersAuth -> modelUser ++: matchPassword(password)
modelUser --> controllersAuth --: isMatch
controllersAuth -> controllersAuth ++: sendTokenResponse(user)
controllersAuth -> client --: token + cookie response

client -> server ++: req.post('/api/v1/auth/me')
server -> routerAuth ++: app.use('/api/v1/auth', auth)
routerAuth -> controllersAuth ++: getMe()
controllersAuth -> modelUser ++: findById(req.user.id)
modelUser -> UsersDatabase ++: query
UsersDatabase --> modelUser --: user
controllersAuth <-- modelUser --: user
controllersAuth -> client --: user data response

client -> server ++: req.get('/api/v1/auth/logout')
server -> routerAuth ++: app.use('/api/v1/auth', auth)
routerAuth -> controllersAuth ++: logout()
controllersAuth -> client --: clear cookie + success response

@enduml